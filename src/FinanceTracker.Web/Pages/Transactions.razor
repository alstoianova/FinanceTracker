@page "/transactions"
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation
<h1>Transactions</h1>

<div style="
    display:flex;
    gap:20px;
    margin-bottom:30px;
    flex-wrap:wrap;">

    <div style="
        background:white;
        padding:20px;
        border-radius:12px;
        box-shadow:0 2px 8px rgba(0,0,0,0.05);
        min-width:220px;">

        <h3>Total Balance</h3>

        <h2 style="color:#2563eb;">
            @TotalBalance MDL
        </h2>

    </div>

    <div style="
        background:white;
        padding:20px;
        border-radius:12px;
        box-shadow:0 2px 8px rgba(0,0,0,0.05);
        min-width:220px;">

        <h3>Total Income</h3>

        <h2 style="color:green;">
            +@TotalIncome MDL
        </h2>

    </div>

    <div style="
        background:white;
        padding:20px;
        border-radius:12px;
        box-shadow:0 2px 8px rgba(0,0,0,0.05);
        min-width:220px;">

        <h3>Total Expense</h3>

        <h2 style="color:red;">
            -@TotalExpense MDL
        </h2>

    </div>

</div>

<h3>Create Transaction</h3>

<div style="margin-bottom:20px;">

    <input type="number"
           placeholder="Amount"
           @bind="newTransaction.Amount"
           style="padding:8px; margin-right:10px;" />

    <input placeholder="Description"
           @bind="newTransaction.Description"
           style="padding:8px; margin-right:10px;" />

    <br />
    <br />

    <select @bind="newTransaction.Type"
            style="padding:8px; margin-right:10px;">
        <option value="Income">Income</option>
        <option value="Expense">Expense</option>
    </select>

    <select @bind="newTransaction.AccountId"
            style="padding:8px; margin-right:10px;">

        @foreach (var account in accounts)
        {
            <option value="@account.Id">
                @account.Name
            </option>
        }

    </select>

    <select @bind="newTransaction.CategoryId"
            style="padding:8px; margin-right:10px;">

        @foreach (var category in categories)
        {
            <option value="@category.Id">
                @category.Name
            </option>
        }

    </select>

    <button @onclick="CreateTransaction"
            style="
                padding:8px 16px;
                background-color:#2563eb;
                color:white;
                border:none;
                border-radius:8px;
                cursor:pointer;">

        Create

    </button>

</div>

<hr />

<h3>Filters</h3>

<select @bind="selectedType"
        style="padding:8px; margin-bottom:20px;">

    <option value="All">All</option>
    <option value="Income">Income</option>
    <option value="Expense">Expense</option>

</select>

<hr />

@if (transactions is null)
{
    <p>Loading...</p>
}
else
{
    @foreach (var transaction in filteredTransactions)
{
    <div @key="transaction.Id"
         style="
            border:1px solid #dcdcdc;
            border-radius:12px;
            padding:20px;
            margin-bottom:15px;
            background-color:white;
            box-shadow:0 2px 8px rgba(0,0,0,0.05);">

            <h3 style="
                color:@(transaction.Type == "Income"
                    ? "green"
                    : "red")">

                @(transaction.Type == "Income" ? "+" : "-")
                @transaction.Amount MDL

            </h3>

            <p>
                <b>Type:</b>
                @transaction.Type
            </p>

            <p>
                <b>Description:</b>
                @transaction.Description
            </p>

            <p>
                <b>Account:</b>
                @transaction.AccountName
            </p>

            <p>
                <b>Category:</b>
                @transaction.CategoryName
            </p>

            <p>
                <b>Date:</b>
                @transaction.Date.ToString("dd.MM.yyyy HH:mm")
            </p>

            <div style="display:flex; gap:10px; margin-top:15px;">

                <button
                    style="
                        background-color:#2563eb;
                        color:white;
                        border:none;
                        padding:8px 14px;
                        border-radius:8px;
                        cursor:pointer;"
                    @onclick="() => StartEdit(transaction)">

                    Edit

                </button>

                <button
                    style="
                        background-color:#dc3545;
                        color:white;
                        border:none;
                        padding:8px 14px;
                        border-radius:8px;
                        cursor:pointer;"
                    @onclick="() => DeleteTransaction(transaction.Id)">

                    Delete

                </button>

            </div>

            @if (editingTransactionId == transaction.Id)
            {
                <div style="
                    margin-top:20px;
                    padding:15px;
                    border:1px solid #dcdcdc;
                    border-radius:10px;
                    background:#f9fafb;">

                    <input type="number"
                           @bind="editTransaction.Amount"
                           style="padding:8px; margin-right:10px;" />

                    <input
                        @bind="editTransaction.Description"
                        style="padding:8px; margin-right:10px;" />

                    <br />
                    <br />

                    <select @bind="editTransaction.Type"
                            style="padding:8px; margin-right:10px;">

                        <option value="Income">Income</option>
                        <option value="Expense">Expense</option>

                    </select>

                    <select @bind="editTransaction.CategoryId"
                            style="padding:8px; margin-right:10px;">

                        @foreach (var category in categories)
                        {
                            <option value="@category.Id">
                                @category.Name
                            </option>
                        }

                    </select>

                    <button
                        style="
                            background-color:#16a34a;
                            color:white;
                            border:none;
                            padding:8px 14px;
                            border-radius:8px;
                            cursor:pointer;"
                        @onclick="SaveEdit">

                        Save

                    </button>

                </div>
            }

        </div>
    }
}

@code {

    private List<TransactionDto>? transactions;

    private List<AccountDto> accounts = new();

    private List<CategoryDto> categories = new();

    private string selectedType = "All";

    private Guid? editingTransactionId = null;

    private EditTransactionRequest editTransaction =
    new EditTransactionRequest();

    private decimal TotalIncome =>
        transactions?
            .Where(t => t.Type == "Income")
            .Sum(t => t.Amount)
        ?? 0;

    private decimal TotalExpense =>
        transactions?
            .Where(t => t.Type == "Expense")
            .Sum(t => t.Amount)
        ?? 0;

    private decimal TotalBalance =>
        TotalIncome - TotalExpense;

    private IEnumerable<TransactionDto> filteredTransactions
    {
        get
        {
            if (transactions == null)
            {
                return Enumerable.Empty<TransactionDto>();
            }

            if (selectedType == "All")
            {
                return transactions;
            }

            return transactions.Where(t =>
                t.Type == selectedType);
        }
    }

    private CreateTransactionRequest newTransaction =
        new()
        {
            Type = "Expense",
            Date = DateTime.UtcNow
        };

    protected override async Task OnInitializedAsync()
    {
        await LoadTransactions();

        accounts =
            await Http.GetFromJsonAsync<List<AccountDto>>(
                "http://localhost:5228/accounts")
            ?? new();

        categories =
            await Http.GetFromJsonAsync<List<CategoryDto>>(
                "http://localhost:5228/categories")
            ?? new();

        if (accounts.Any())
        {
            newTransaction.AccountId =
                accounts.First().Id;
        }

        if (categories.Any())
        {
            newTransaction.CategoryId =
                categories.First().Id;
        }
    }

    private async Task LoadTransactions()
    {
        try
        {
            transactions =
                await Http.GetFromJsonAsync<List<TransactionDto>>(
                    "http://localhost:5228/transactions")
                ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);

            transactions = new();
        }
    }

  private async Task CreateTransaction()
{
    try
    {
        newTransaction.Date = DateTime.UtcNow;

        var response =
            await Http.PostAsJsonAsync(
                "http://localhost:5228/transactions",
                newTransaction);

        if (response.IsSuccessStatusCode)
        {
            await LoadTransactions();

            newTransaction = new()
            {
                Type = "Expense",
                Date = DateTime.UtcNow
            };

            if (accounts.Any())
            {
                newTransaction.AccountId =
                    accounts.First().Id;
            }

            if (categories.Any())
            {
                newTransaction.CategoryId =
                    categories.First().Id;
            }

            await InvokeAsync(StateHasChanged);
        }
    }
    catch (Exception ex)
    {
        Console.WriteLine(ex.Message);
    }
}

    private void StartEdit(TransactionDto transaction)
{
    editingTransactionId = transaction.Id;

    var category =
        categories.FirstOrDefault(c =>
            c.Name == transaction.CategoryName);

    var account =
        accounts.FirstOrDefault(a =>
            a.Name == transaction.AccountName);

  editTransaction = new EditTransactionRequest
    {
        Amount = transaction.Amount,
        Description = transaction.Description,
        Type = transaction.Type,
        CategoryId = category?.Id ?? Guid.Empty,
        AccountId = account?.Id ?? Guid.Empty
    };
}

 private async Task SaveEdit()
{
    if (editingTransactionId == null)
    {
        return;
    }

    try
    {
        var response =
            await Http.PutAsJsonAsync(
                $"http://localhost:5228/transactions/{editingTransactionId}",
                editTransaction);

        if (response.IsSuccessStatusCode)
        {
            // вручную обновляем объект в списке
            var transaction =
                transactions?.FirstOrDefault(t =>
                    t.Id == editingTransactionId);

            if (transaction != null)
            {
                transaction.Amount =
                    editTransaction.Amount;

                transaction.Description =
                    editTransaction.Description;

                transaction.Type =
                    editTransaction.Type;

                var category =
                    categories.FirstOrDefault(c =>
                        c.Id == editTransaction.CategoryId);

                transaction.CategoryName =
                    category?.Name ?? "";
            }

            editingTransactionId = null;

            StateHasChanged();
        }
    }
    catch (Exception ex)
    {
        Console.WriteLine(ex.Message);
    }
}


    private async Task DeleteTransaction(Guid id)
    {
        var response =
            await Http.DeleteAsync(
                $"http://localhost:5228/transactions/{id}");

        if (response.IsSuccessStatusCode)
        {
            await LoadTransactions();
        }
    }

    public class TransactionDto
    {
        public Guid Id { get; set; }

        public decimal Amount { get; set; }

        public string Description { get; set; } = "";

        public string Type { get; set; } = "";

        public string AccountName { get; set; } = "";

        public string CategoryName { get; set; } = "";

        public DateTime Date { get; set; }
    }

    public class AccountDto
    {
        public Guid Id { get; set; }

        public string Name { get; set; } = "";
    }

    public class CategoryDto
    {
        public Guid Id { get; set; }

        public string Name { get; set; } = "";
    }

    public class CreateTransactionRequest
    {
        public decimal Amount { get; set; }

        public string Description { get; set; } = "";

        public string Type { get; set; } = "Expense";

        public Guid AccountId { get; set; }

        public Guid CategoryId { get; set; }

        public DateTime Date { get; set; }
    }
    public class EditTransactionRequest
{
    public decimal Amount { get; set; }

    public string Description { get; set; } = "";

    public string Type { get; set; } = "Expense";

    public Guid AccountId { get; set; }

    public Guid CategoryId { get; set; }
}
}